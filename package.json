  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
