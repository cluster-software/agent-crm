{
  "name": "@agent-crm/sdk",
  "version": "1.0.1",
  "description": "The headless CRM for Claude",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "libphonenumber-js": "^1.13.2",
    "pg": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
