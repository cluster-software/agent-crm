{
  "name": "@agent-crm/sdk",
  "version": "0.1.2",
  "description": "Agent CRM SDK: programmatic API for headless CRM operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@lix-js/sdk": "0.6.0-preview.3",
    "better-sqlite3": "^12.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
